# Database
# Lightweight default: SQLite file, no external service.
DATABASE_URL=file:./sfdev.db
# Postgres alternative (uncomment + comment the SQLite line above):
# DATABASE_URL=postgresql://sfdev:sfdev@localhost:5432/sfdev

# Session (must be at least 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# AI provider — defaults to Anthropic API
ANTHROPIC_API_KEY=

# Optional: use AWS Bedrock instead of the Anthropic API directly
# AI_PROVIDER=bedrock
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
# AWS credentials are read from ~/.aws or AWS_* env vars

# Salesforce auth.
#
# Local dev: leave these unset — the app falls back to the Salesforce CLI
# device flow against the built-in PlatformCLI client. Zero config.
#
# Hosted / SaaS: register an External Client App (ECA) in your own org
# and paste its Consumer Key / Secret here. (Connected App creation was
# disabled across all orgs in Spring '26 — ECA is the only path for new
# work. The OAuth wire protocol is identical; only the metadata changes.)
# See docs/DEPLOY.md for the full walkthrough.
#
# SF_CLIENT_ID=
# SF_CLIENT_SECRET=
# SF_CALLBACK_URL=https://your-app.vercel.app/auth/callback

# Optional: embeddings for the RAG toolset (retrieve_org_context / index_org_documents).
# OpenAI-compatible /embeddings endpoint — works with OpenAI, Voyage, or a gateway.
# EMBEDDING_API_KEY=
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_MODEL=text-embedding-3-small
