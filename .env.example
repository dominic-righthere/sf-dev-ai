# Database
# Lightweight default: SQLite file, no external service.
DATABASE_URL=file:./sfdev.db
# Postgres alternative (uncomment + comment the SQLite line above):
# DATABASE_URL=postgresql://sfdev:sfdev@localhost:5432/sfdev

# Session (must be at least 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# AI provider — defaults to Anthropic API
ANTHROPIC_API_KEY=

# Optional: use AWS Bedrock instead of the Anthropic API directly
# AI_PROVIDER=bedrock
# AWS_REGION=us-east-1
# BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
# AWS credentials are read from ~/.aws or AWS_* env vars

# Optional: custom Salesforce Connected App
# If unset, the app uses the Salesforce CLI device flow (zero-config).
# SF_CLIENT_ID=
# SF_CLIENT_SECRET=
# SF_CALLBACK_URL=http://localhost:3000/auth/callback
